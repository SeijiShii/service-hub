# .env.production.example — service-hub 本番 env テンプレート
#
# 使い方:
#   cp .env.production.example .env.production.local   # .env.production.local は gitignore 済み (.env*.local)
#   .env.production.local の各 KEY= の後ろに「本番の値」を記入        # 各プロバイダのダッシュボードから取得 / 生成
#   ! bash scripts/deploy-prod.sh                      # Vercel 本番 env に同期 → デプロイ
#   （env だけ更新する時は: ! bash scripts/sync-prod-env.sh）
#
# 命名規約 (Vite): `.local` は「git にコミットしない秘密ファイル」の意。環境は `production`。
#   .env.local            = dev/ローカル開発用 (本番値を書かない)
#   .env.production.local = 本番用 (本番値の単一 source。手入力コピペを排除)
# dev (.env.local) と prod (.env.production.local) は別ファイル = 混ざらない。
#
# 注意: コメントは「行頭 #」で書くこと。値の右側にインラインコメントを書くと、
#       同期スクリプトが除去はするが (空白+# 以降を trim)、値だけを書くのが安全。

# --- HUB 自身 ---
# Neon 本番 connection string
DATABASE_URL=
# Clerk (本番 instance) Secret Key (sk_live_...)
CLERK_SECRET_KEY=
# Clerk (本番 instance) Publishable Key (pk_live_...、build 時に焼込)
VITE_CLERK_PUBLISHABLE_KEY=
# seiji の Clerk user id (production instance のもの。これ以外は 403)
ALLOWED_USER_ID=
# Vercel Cron -> /api/cron/collect 認証 (openssl rand -hex 32 の出力)
CRON_SECRET=
# 任意: HUB 自身のエラー監視 (未使用なら空で可)
SENTRY_DSN=

# --- pull 対象 PaaS の read トークン (アカウント単位・サービス追加で不変) ---
# Vercel access token (read 用途。Vercel は read-only 指定不可=全アクセス、狭スコープ+安全保管で運用)
VERCEL_API_TOKEN=
# Neon API key (read scope)
NEON_API_KEY=
# 任意 (R2、Phase 2)
CLOUDFLARE_API_TOKEN=
# 任意 (エラー件数、Phase 2)
SENTRY_AUTH_TOKEN=

# --- service-info 連携 (全サービス共通 1 本、[D20260528-002]) ---
# 各監視対象サービス側 env にも同じ値を設定 (hana-memo retrofit 後に有効化)
HUB_SERVICE_INFO_SECRET=

# --- 無登録 feedback ソース (任意、inbox-pull-source revise) ---
# services 登録なしで feedback pull する外部ソースを JSON 配列で定義。
# 各 GET /api/hub/feedback は上記 HUB_SERVICE_INFO_SECRET で認証。空なら従来同一 (registered のみ)。
# 例: HUB_FEEDBACK_SOURCES=[{"slug":"shipyard","name":"Shipyard","url":"https://givers.work"}]
HUB_FEEDBACK_SOURCES=
