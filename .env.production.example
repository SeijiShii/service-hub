# .env.production.example — service-hub 本番 env テンプレート
#
# 使い方:
#   cp .env.production.example .env.production.local   # .env.production.local は gitignore 済み (.env*.local)
#   .env.production.local に「本番の値」を記入        # 各プロバイダのダッシュボードから取得 / 生成
#   ! bash scripts/deploy-prod.sh                      # ファイルを Vercel 本番 env に同期 → デプロイ
#
# 命名規約 (Vite): `.local` は「git にコミットしない秘密ファイル」の意。環境は `production`。
#   .env.local            = dev/ローカル開発用 (本番値を書かない)
#   .env.production.local = 本番用 (このファイルが本番値の単一 source。手入力コピペを排除)
# dev (.env.local) と prod (.env.production.local) は別ファイル = 混ざらない。
# Vite は .env.production.local を production ビルド時のみロード (通常の vite/vercel dev では読まれない)。

# --- HUB 自身 ---
DATABASE_URL=                  # Neon 本番 connection string
CLERK_SECRET_KEY=              # Clerk (本番 instance) Secret Key
VITE_CLERK_PUBLISHABLE_KEY=    # Clerk (本番 instance) Publishable Key (build 時に焼込)
ALLOWED_USER_ID=               # seiji の Clerk user id (これ以外は 403)
CRON_SECRET=                   # Vercel Cron → /api/cron/collect 認証 (例: openssl rand -hex 32 の出力)
SENTRY_DSN=                    # 任意: HUB 自身のエラー監視

# --- pull 対象 PaaS の read-only トークン (アカウント単位・サービス追加で不変) ---
VERCEL_API_TOKEN=              # read scope (deploy/帯域 pull)
NEON_API_KEY=                  # read scope (DB 使用量 pull)
CLOUDFLARE_API_TOKEN=          # 任意 (R2、Phase 2)
SENTRY_AUTH_TOKEN=             # 任意 (エラー件数、Phase 2)

# --- service-info 連携 (全サービス共通 1 本、[D20260528-002]) ---
HUB_SERVICE_INFO_SECRET=       # 各監視対象サービス側 env にも同じ値を設定 (hana-memo retrofit 後に有効化)
