# === HUB 自身 ===
DATABASE_URL=postgres://USER:PASS@HOST/DB        # Neon (HUB の DB)
CLERK_PUBLISHABLE_KEY=pk_test_xxx                # HUB アクセス制御
CLERK_SECRET_KEY=sk_test_xxx
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx  # HUB 自身の監視

# === pull 対象 PaaS の read-only トークン (アカウント単位、サービス追加で不変) ===
VERCEL_API_TOKEN=                                 # read scope
NEON_API_KEY=                                     # read scope
CLOUDFLARE_API_TOKEN=                             # R2 read scope (Phase 2)
SENTRY_AUTH_TOKEN=                                # read scope (Phase 2)

# === service-info 連携 (全サービス共通 1 本、[D20260528-002] 秘密ゼロ化) ===
# 各サービスの service-info エンドポイントを Bearer 認証する共通シークレット。
# 各サービス側 env にも同じ値を設定する。MAU は各サービスが service-info で自己申告 (Clerk API 直叩き廃止)。
HUB_SERVICE_INFO_SECRET=
# 注: per-service の *_CLERK_SECRET / *_HUB_SECRET は廃止 (新サービス追加で .env を増やさない)

# === HUB アクセス制御 (bootstrap) ===
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx     # フロント Clerk
ALLOWED_USER_ID=user_xxx                    # seiji の Clerk user id (これ以外は 403)
CRON_SECRET=                                # Vercel Cron → /api/cron/collect 認証
